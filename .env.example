MONGODB_URI=mongodb://127.0.0.1:27017/relay
# generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Public base URL of this deployment — swap to the real Vercel URL (or custom domain) once assigned
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform default sender — used when a user/team hasn't configured their own SenderConfig
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
